<%- include('./partials/header') %>


<% if (success && success.length > 0) { %>
  <div
    id="flash-wrapper"
    class="w-full bg-transparent overflow-hidden transition-all duration-500 max-h-40"
  >
    <div
      id="flash-msg"
      class="
        mx-3 sm:mx-auto
        mt-3
        max-w-3xl
        bg-yellow-100 border border-yellow-300
        text-yellow-800
        px-4 py-3
        rounded-lg shadow
        flex items-start sm:items-center gap-3
        text-sm sm:text-base
      "
    >
      <span class="flex-1 leading-relaxed">
        <%= success[0] %>
      </span>

      <button
        onclick="closeFlash()"
        class="text-yellow-700 hover:text-yellow-900 text-xl leading-none"
        aria-label="Close"
      >
        &times;
      </button>
    </div>
  </div>
<% } %>

<!-- PAGE CONTENT -->
<div class="min-h-screen bg-gray-100 px-3 sm:px-6 lg:px-16 py-6 sm:py-10 space-y-8">

  <!-- PAGE TITLE -->
  <h2 class="font-bold text-lg sm:text-[22px] text-gray-700 ml-1 sm:ml-4">
    My Account
  </h2>

  <!-- PROFILE OVERVIEW -->
  <div class="bg-white rounded-xl sm:rounded-2xl shadow-md p-4 sm:p-6 border border-gray-300">

    <h3 class="font-semibold text-base sm:text-[18px] text-gray-700 mb-4 border-b border-gray-400 pb-2">
      Profile Overview
    </h3>

    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-4">

      <img
        src="<%= user.picture || '/images/default/avatar.jpg' %>"
        alt="Profile"
        class="w-24 h-24 sm:w-32 sm:h-32 rounded-full border shadow object-cover"
      />

      <div class="w-full text-center sm:text-left space-y-1">
        <p class="text-sm sm:text-base text-gray-700">
          <strong>Name:</strong> <%= user.fullname %>
        </p>

        <p class="text-sm sm:text-base text-gray-700 break-all">
          <strong>Email:</strong> <%= user.email %>
        </p>

        <% if (user.phone) { %>
        <p class="text-sm sm:text-base text-gray-700">
          <strong>Phone:</strong> <%= user.phone %>
        </p>
        <% } %>

        <a
          href="/account/edit"
          class="mt-3 inline-block w-full sm:w-auto text-center bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg text-sm font-semibold transition"
        >
          Edit Profile
        </a>
      </div>

    </div>
  </div>

  <!-- ADDRESS BOOK -->
  <div class="bg-white rounded-xl sm:rounded-2xl shadow-md p-4 sm:p-6 border border-gray-300">

    <div class="flex flex-col sm:flex-row sm:justify-between gap-3 mb-4">
      <h3 class="font-semibold text-base sm:text-[18px] text-gray-700">
        Address Book
      </h3>

      <a
        href="/account/addresses/new"
        class="w-full sm:w-auto text-center bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-md text-sm"
      >
        + Add Address
      </a>
    </div>

    <% if (user.addresses.length === 0) { %>
      <p class="text-gray-500 italic text-sm">
        No saved addresses yet.
      </p>
    <% } else { %>
      <ul class="space-y-4">
        <% user.addresses.forEach(addr => { %>
          <li class="bg-gray-50 p-4 rounded-lg border text-sm sm:text-base">

            <p class="text-gray-700 font-medium leading-relaxed">
              <%= addr.line1 %>, <%= addr.city %>, <%= addr.state %> - <%= addr.pincode %>
            </p>

            <div class="mt-2">
              <% if (addr.isDefault) { %>
                <span class="text-green-600 font-semibold text-sm">
                  Default
                </span>
              <% } else { %>
                <a
                  href="/account/addresses/default/<%= addr._id %>"
                  class="text-blue-600 text-sm hover:underline"
                >
                  Set as Default
                </a>
              <% } %>
            </div>

            <div class="mt-3 flex gap-4 text-sm">
              <a href="/account/addresses/edit/<%= addr._id %>" class="text-blue-600">
                Edit
              </a>
              <a href="/account/addresses/delete/<%= addr._id %>" class="text-red-600">
                Delete
              </a>
            </div>

          </li>
        <% }) %>
      </ul>
    <% } %>
  </div>

  <!-- SECURITY -->
  <div class="bg-white rounded-xl sm:rounded-2xl shadow-md p-4 sm:p-6 border border-gray-300">
    <h3 class="font-semibold text-base sm:text-[18px] text-gray-700 mb-4 border-b pb-2 border-gray-400">
      Security
    </h3>

    <a
      href="/account/changepassword"
      class="block sm:inline-block text-center bg-gray-800 hover:bg-black text-white px-4 py-2 rounded-md text-sm"
    >
      Change Password
    </a>
  </div>

</div>

<!-- FLASH MESSAGE SCRIPT -->
<script>
  function closeFlash() {
    const wrapper = document.getElementById("flash-wrapper");
    if (!wrapper) return;
    wrapper.style.maxHeight = "0px";
    setTimeout(() => wrapper.remove(), 500);
  }

  setTimeout(() => {
    closeFlash();
  }, 1000);
</script>

</body>
</html>
