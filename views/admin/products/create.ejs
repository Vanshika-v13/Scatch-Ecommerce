<%- include('../../adminpartials/header') %>

<div class="max-w-4xl mx-auto px-6 lg:px-16 pb-10">
    <h2 class="text-2xl font-bold mb-6 text-gray-800">Create New Product</h2>

    <% if (success && success.length > 0) { %>
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4">
            <%= success %>
        </div>
    <% } %>

    <% if (error && error.length > 0) { %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
            <%= error %>
        </div>
    <% } %>

    <div class="bg-white rounded-lg shadow-lg p-8">
        <form action="/products/create" method="post" enctype="multipart/form-data" class="space-y-6">
            <!-- Product Image -->
            <div>
                <label class="block mb-2 text-sm font-medium text-gray-700">Product Image</label>
                <input name="image" type="file"
                    class="block w-full text-sm text-gray-900 border border-gray-300 rounded-md cursor-pointer bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>

            <!-- Product Details -->
            <div>
                <h3 class="text-lg font-semibold text-gray-800 mb-3">Product Details</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                        <input name="name" type="text" placeholder="Product Name"
                            class="w-full border border-gray-300 rounded-md p-2 focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Price</label>
                        <input name="price" type="number" placeholder="Product Price"
                            class="w-full border border-gray-300 rounded-md p-2 focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Discount Price</label>
                        <input name="discount" type="number" placeholder="Discount Price"
                            class="w-full border border-gray-300 rounded-md p-2 focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>
                </div>
            </div>

            <!-- Panel Styling -->
            <div>
                <h3 class="text-lg font-semibold text-gray-800 mb-3">Panel Styling</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Background Color</label>
                        <input name="bgcolor" type="text" placeholder="#ffffff"
                            class="w-full border border-gray-300 rounded-md p-2 focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Panel Color</label>
                        <input name="panelcolor" type="text" placeholder="#f3f4f6"
                            class="w-full border border-gray-300 rounded-md p-2 focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Text Color</label>
                        <input name="textcolor" type="text" placeholder="#1f2937"
                            class="w-full border border-gray-300 rounded-md p-2 focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="pt-4">
                <button type="submit"
                    class="bg-blue-600 hover:bg-blue-700 transition text-white px-6 py-2 rounded-md font-medium w-full md:w-auto">
                    Create Product
                </button>
            </div>
        </form>
    </div>
</div>

<%- include('../../adminpartials/footer') %>
