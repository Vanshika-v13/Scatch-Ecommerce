<%- include('./partials/header') %>

<div class="px-6 py-8 lg:px-20 font-sans relative">
  <!-- Cancel button -->
  <a href="/shop" class="absolute top-6 right-6 text-red-600 underline font-medium hover:text-red-800">
    Cancel
  </a>

  <div class="max-w-4xl mx-auto p-6">
    <h2 class="text-xl font-bold mb-6 text-gray-800">Confirm Your Order</h2>

    <!-- Address -->
    <div class="bg-gray-100 p-4 rounded shadow mb-6">
      <p class="mb-2">
        <strong>Delivery Address:</strong>
        <%= address.line1 %>, <%= address.city %>, <%= address.state %> - <%=
        address.pincode %>
      </p>
      <p class="text-sm text-gray-600">
        <strong>Expected Delivery:</strong>
        <%= arrivalDate.toLocaleDateString() %>
      </p>
    </div>

    <!-- Product Summary -->
    <div class="bg-white p-4 rounded shadow-sm mb-6 flex gap-6">
      <img src="<%= product.image %>" class="w-32 h-32 object-cover rounded" alt="Product" />

      <div class="flex-1">
        <h3 class="text-xl font-semibold"><%= product.name %></h3>
        <p>Quantity: <%= quantity %></p>
        <% if (size) { %>
          <p>Size: <%= size %></p>
        <% } %>
        <p>Arriving By: <%= arrivalDate.toLocaleDateString() %></p>
      </div>
    </div>

    <!-- Bill Section -->
    <div class="bg-white p-4 rounded shadow-sm mb-6">
      <h3 class="text-lg font-semibold mb-2">Bill Details</h3>

      <div class="flex justify-between mb-1">
        <span>Base Price (<%=quantity%> × ₹<%= Math.round(price / quantity) %>):</span>
        <span>₹<%= Math.round(price / quantity) * quantity %></span>
      </div>

      <% if(discount > 0) { %>
      <div class="flex justify-between mb-1 text-green-600">
        <span>Discount (<%= discount %>%):</span>
        <span>-₹<%= discountAmount %></span>
      </div>
      <% } %>

      <div class="flex justify-between mb-1">
        <span>Item Total:</span>
        <span>₹<%= price %></span>
      </div>

      <div class="flex justify-between mb-1">
        <span>Shipping Fee:</span>
        <span>₹<%= shippingFee %></span>
      </div>

      <div class="flex justify-between font-bold text-lg border-t pt-2">
        <span>Total:</span>
        <span>₹<%= total %></span>
      </div>
    </div>

    <!-- Payment Method -->
    <div class="bg-white p-4 rounded shadow">
      <h3 class="text-lg font-semibold mb-4">Choose Payment Method</h3>

      <div class="space-y-3 mb-6">
        <label class="flex items-center border p-3 rounded cursor-pointer hover:bg-gray-50">
          <input type="radio" name="paymentMethod" value="COD" checked class="mr-3" id="paymentCODBuy">
          <span class="font-medium text-gray-800">Cash on Delivery (COD)</span>
        </label>

        <label class="flex items-center border p-3 rounded cursor-pointer hover:bg-gray-50">
          <input type="radio" name="paymentMethod" value="UPI" class="mr-3" id="paymentUPIBuy">
          <span class="font-medium text-gray-800">UPI Payment</span>
        </label>
      </div>

      <!-- COD Form -->
      <form id="codFormBuy" action="/buynow/place-order" method="POST" class="block">
        <input type="hidden" name="productId" value="<%= product._id %>" />
        <input type="hidden" name="quantity" value="<%= quantity %>" />
        <% if (size) { %>
          <input type="hidden" name="size" value="<%= size %>" />
        <% } %>
        <input type="hidden" name="addressId" value="<%= address._id %>" />
        <input type="hidden" name="paymentMethod" value="COD">
        <button type="submit" class="w-full bg-yellow-500 hover:bg-yellow-600 text-white px-6 py-2 rounded font-medium">
          Place Order with COD
        </button>
      </form>

      <!-- UPI Payment Button -->
      <button id="upiPayBtnBuy" style="display: none;" onclick="handleBuyNowUPI()" class="w-full bg-yellow-500 hover:bg-yellow-600 text-white px-6 py-2 rounded font-medium">
        Pay with UPI
      </button>

      <input type="hidden" id="productIdBuy" value="<%= product._id %>">
      <input type="hidden" id="quantityBuy" value="<%= quantity %>">
      <input type="hidden" id="sizeBuy" value="<%= size || '' %>">
      <input type="hidden" id="addressIdBuy" value="<%= address._id %>">
      <input type="hidden" id="totalAmountBuy" value="<%= total %>">
    </div>

  </div>
</div>

<%- include('./partials/footer') %>