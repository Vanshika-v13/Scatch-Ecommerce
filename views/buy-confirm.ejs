<%- include('./partials/header') %>

<div class="px-4 sm:px-6 py-6 sm:py-8 lg:px-20 font-sans relative">
  <!-- Cancel button -->
  <a href="/shop" class="absolute top-4 sm:top-6 right-4 sm:right-6 text-red-600 underline font-medium hover:text-red-800 text-sm sm:text-base">
    Cancel
  </a>

  <div class="max-w-4xl mx-auto">
    <h2 class="text-xl sm:text-2xl font-bold mb-6 text-gray-800 mt-8">Confirm Your Order</h2>

    <!-- Address -->
    <div class="bg-gray-100 p-4 sm:p-6 rounded shadow mb-4 sm:mb-6">
      <p class="mb-3 text-sm sm:text-base">
        <strong>Delivery Address:</strong>
      </p>
      <p class="text-sm sm:text-base text-gray-700 mb-2">
        <%= address.line1 %>, <%= address.city %>, <%= address.state %> - <%= address.pincode %>
      </p>
      <p class="text-xs sm:text-sm text-gray-600">
        <strong>Expected Delivery:</strong> <%= arrivalDate.toLocaleDateString() %>
      </p>
    </div>

    <!-- Product Summary -->
    <div class="bg-white p-4 sm:p-6 rounded shadow-sm mb-4 sm:mb-6">
      <div class="flex flex-col sm:flex-row gap-4 sm:gap-6">
        <img src="<%= product.image %>" class="w-full sm:w-32 h-48 sm:h-32 object-cover rounded" alt="Product" />
        <div class="flex-1">
          <h3 class="text-lg sm:text-xl font-semibold mb-2"><%= product.name %></h3>
          <p class="text-sm sm:text-base mb-1">Quantity: <%= quantity %></p>
          <% if (size) { %>
            <p class="text-sm sm:text-base mb-1">Size: <%= size %></p>
          <% } %>
          <p class="text-sm sm:text-base text-gray-600">Arriving By: <%= arrivalDate.toLocaleDateString() %></p>
        </div>
      </div>
    </div>

    <!-- Bill Section -->
    <div class="bg-white p-4 sm:p-6 rounded shadow-sm mb-4 sm:mb-6">
      <h3 class="text-lg font-semibold mb-4">Bill Details</h3>

      <div class="space-y-2 text-sm sm:text-base">
        <div class="flex justify-between">
          <span>Base Price (<%=quantity%> × ₹<%= Math.round(price / quantity) %>):</span>
          <span>₹<%= Math.round(price / quantity) * quantity %></span>
        </div>

        <% if(discount > 0) { %>
        <div class="flex justify-between text-green-600">
          <span>Discount (<%= discount %>%):</span>
          <span>-₹<%= discountAmount %></span>
        </div>
        <% } %>

        <div class="flex justify-between">
          <span>Item Total:</span>
          <span>₹<%= price %></span>
        </div>

        <div class="flex justify-between">
          <span>Shipping Fee:</span>
          <span>₹<%= shippingFee %></span>
        </div>

        <div class="flex justify-between font-bold text-base sm:text-lg border-t pt-3 text-gray-900">
          <span>Total:</span>
          <span>₹<%= total %></span>
        </div>
      </div>
    </div>

    <!-- Payment Method -->
    <div class="bg-white p-4 sm:p-6 rounded shadow">
      <h3 class="text-lg font-semibold mb-4">Choose Payment Method</h3>

      <div class="space-y-3 mb-6">
        <label class="flex items-center border p-3 sm:p-4 rounded cursor-pointer hover:bg-gray-50 transition">
          <input type="radio" name="paymentMethod" value="COD" checked class="mr-3 w-4 h-4" id="paymentCODBuy">
          <span class="font-medium text-gray-800 text-sm sm:text-base">Cash on Delivery (COD)</span>
        </label>

        <label class="flex items-center border p-3 sm:p-4 rounded cursor-pointer hover:bg-gray-50 transition">
          <input type="radio" name="paymentMethod" value="Razorpay" class="mr-3 w-4 h-4" id="paymentRazorpayBuy">
          <span class="font-medium text-gray-800 text-sm sm:text-base">Pay with Razorpay</span>
        </label>
      </div>

      <!-- COD Form -->
      <form id="codFormBuy" action="/buynow/place-order" method="POST" class="block space-y-4">
        <input type="hidden" name="productId" value="<%= product._id %>" />
        <input type="hidden" name="quantity" value="<%= quantity %>" />
        <% if (size) { %>
          <input type="hidden" name="size" value="<%= size %>" />
        <% } %>
        <input type="hidden" name="addressId" value="<%= address._id %>" />
        <input type="hidden" name="paymentMethod" value="COD">
        <button type="submit" id="codBtnBuy" class="w-full bg-yellow-500 hover:bg-yellow-600 text-white px-4 sm:px-6 py-3 rounded font-medium text-sm sm:text-base transition">
          Place Order with COD
        </button>
      </form>

      <!-- Razorpay Payment Button -->
      <button id="razorpayBtnBuy" style="display: none;" class="w-full bg-yellow-500 hover:bg-yellow-600 text-white px-4 sm:px-6 py-3 rounded font-medium text-sm sm:text-base transition">
        Pay with Razorpay
      </button>

      <input type="hidden" id="productIdBuy" value="<%= product._id %>">
      <input type="hidden" id="quantityBuy" value="<%= quantity %>">
      <input type="hidden" id="sizeBuy" value="<%= size || '' %>">
      <input type="hidden" id="addressIdBuy" value="<%= address._id %>">
      <input type="hidden" id="totalAmountBuy" value="<%= total %>">
    </div>

  </div>
</div>

<%- include('./partials/footer') %>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  const paymentMethodRadiosBuy = document.querySelectorAll('input[name="paymentMethod"]');
  const codFormBuy = document.getElementById('codFormBuy');
  const codBtnBuy = document.getElementById('codBtnBuy');
  const razorpayBtnBuy = document.getElementById('razorpayBtnBuy');

  const productIdBuy = document.getElementById('productIdBuy').value;
  const quantityBuy = document.getElementById('quantityBuy').value;
  const sizeBuy = document.getElementById('sizeBuy').value;
  const addressIdBuy = document.getElementById('addressIdBuy').value;
  const totalAmountBuy = parseFloat(document.getElementById('totalAmountBuy').value);

  paymentMethodRadiosBuy.forEach(radio => {
    radio.addEventListener('change', (e) => {
      if (e.target.value === 'COD') {
        codFormBuy.style.display = 'block';
        razorpayBtnBuy.style.display = 'none';
      } else if (e.target.value === 'Razorpay') {
        codFormBuy.style.display = 'none';
        razorpayBtnBuy.style.display = 'block';
      }
    });
  });

  razorpayBtnBuy.addEventListener('click', async (e) => {
    e.preventDefault();
    
    try {
      // Create order on backend
      const response = await fetch('/buynow/place-order', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          productId: productIdBuy,
          quantity: parseInt(quantityBuy),
          size: sizeBuy || null,
          addressId: addressIdBuy,
          paymentMethod: 'Razorpay'
        })
      });

      const data = await response.json();

      if (!data.success) {
        showAppAlert('Failed to create order: ' + data.message);
        return;
      }

      const orderId = data.orderId;
      const options = {
        key: data.keyId,
        amount: data.amount * 100, // Convert to paise
        currency: data.currency,
        name: 'Scatch Store',
        description: 'Order Payment',
        order_id: data.razorpayOrderId,
        prefill: {
          name: data.userName,
          email: data.userEmail,
          contact: data.userPhone
        },
        theme: {
          color: '#3399cc'
        },
        handler: function(response) {
          // Verify payment on backend
          verifyPaymentBuyNow(orderId, data.razorpayOrderId, response.razorpay_payment_id, response.razorpay_signature);
        },
        modal: {
          ondismiss: function() {
            console.log('Payment modal closed');
          }
        }
      };

      const rzp = new Razorpay(options);
      rzp.open();
    } catch (error) {
      console.error('Error:', error);
      showAppAlert('An error occurred while processing payment');
    }
  });

  async function verifyPaymentBuyNow(orderId, razorpayOrderId, paymentId, signature) {
    try {
      const response = await fetch('/verify-razorpay-payment', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          orderId: orderId,
          razorpayOrderId: razorpayOrderId,
          razorpayPaymentId: paymentId,
          razorpaySignature: signature
        })
      });

      const data = await response.json();

      if (data.success) {
        showAppAlert('Payment successful!');
        window.location.href = `/order-success/${orderId}`;
      } else {
        showAppAlert('Payment verification failed: ' + data.message);
      }
    } catch (error) {
      console.error('Error:', error);
      showAppAlert('Payment verification error');
    }
  }
</script>