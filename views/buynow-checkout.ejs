<%- include('./partials/header') %>

<div class="px-6 py-8 lg:px-20 font-sans relative">
  <!-- Cancel button top-right -->
 <a href="/shop" class="absolute top-6 right-6  text-red-600 hover:text-red-800 underline font-medium ">
  Cancel
</a>



  <h2 class="text-xl md:text-[21px] mt-8  font-bold mb-6 text-gray-800">Buy Now - Checkout</h2>

  <% if (error.length > 0) { %>
    <div class="bg-red-100 text-red-600 px-4 py-2 rounded mb-4"><%= error[0] %></div>
  <% } %>

  <% if (success.length > 0) { %>
    <div class="bg-green-100 text-yellow-500 px-4 py-2 rounded mb-4"><%= success[0] %></div>
  <% } %>

  <!-- Client-side Error Message -->
  <div id="client-error" class="hidden bg-red-100 text-red-600 px-4 py-2 rounded mb-4"></div>

  <form method="POST" action="/buynow/confirm" class="space-y-6">
       <input type="hidden" name="productId" value="<%= product._id %>">
    <!-- Product Summary -->
    <div class="bg-white p-6 rounded-lg shadow-lg">
  <div class="flex gap-6 items-center">

    <!-- Product Image -->
    <img
      src="<%= product.image %>"
      alt="<%= product.name %>"
      class="w-28 h-28 object-cover rounded-lg border"
    />

    <!-- Product Details -->
    <div class="space-y-2">
      <h3 class="text-lg font-semibold">Product: <%= product.name %></h3>
      <p class="text-gray-700">Price: ₹<%= product.price %></p>

      <div class="flex items-center gap-2">
        <label for="quantity" class="text-sm text-gray-700">Quantity:</label>
        <input
          type="number"
          id="quantity"
          name="quantity"
          value="1"
          min="1"
          class="w-16 border-gray-300 rounded-md px-2 py-1 focus:outline-none focus:ring-2 focus:ring-yellow-400"
          required
        />
      </div>
    </div>

  </div>
</div>


    <!-- Address Selection -->
    <div class="bg-white p-6 rounded-lg shadow-lg">
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-lg font-semibold text-gray-800">Select Address</h3>
        <a href="/account" class="text-blue-600 text-sm underline">Change / Add Address</a>
      </div>

      <% if (addresses.length === 0) { %>
        <p class="text-gray-500">No saved addresses. 
          <a href="/account/addresses/new?redirect=/buynow/<%= product._id %>" class="text-blue-600 underline">Add one here</a>.
        </p>
      <% } else { %>
        <select name="addressId" class="w-full sm:w-3/4 p-3 rounded-md text-gray-700 bg-gray-100 focus:ring-2 focus:ring-yellow-400 focus:outline-none" required>
          <% addresses.forEach(address => { %>
            <option value="<%= address._id %>" <%= address._id.toString() === defaultAddressId ? "selected" : "" %>>
              <%= address.line1 ? address.line1 + ', ' : '' %>
              <%= address.city ? address.city + ', ' : '' %>
              <%= address.state ? address.state + ', ' : '' %>
              <%= address.pincode ? address.pincode : '' %>
            </option>
          <% }) %>
        </select>
      <% } %>
    </div>

    <!-- Payment Method -->
    <div class="bg-white p-6 rounded-lg shadow-lg">
      <h3 class="text-lg font-semibold text-gray-800 mb-4">Select Payment Method</h3>
      <div class="space-y-2">
        <label class="flex items-center gap-2">
          <input type="radio" name="paymentMethod" value="cod" required class="accent-yellow-500"> Cash on Delivery
        </label>
        <label class="flex items-center gap-2">
          <input type="radio" name="paymentMethod" value="upi" required class="accent-yellow-500"> UPI
        </label>
      </div>
    </div>

    <!-- Submit Button -->
    <div class="flex justify-center">
      <button type="submit" class="bg-yellow-500 hover:bg-yellow-600 text-white px-6 py-3 rounded-lg text-lg font-medium  transition">
        Continue
      </button>
    </div>
    
  </form>
</div>

<script>
  document.querySelector("form").addEventListener("submit", function (e) {
    const addressSelect = document.querySelector('select[name="addressId"]');
    const errorBox = document.getElementById("client-error");

    if (!addressSelect || !addressSelect.value) {
      e.preventDefault();
      errorBox.textContent = "Please select an address before continuing.";
      errorBox.classList.remove("hidden");
      errorBox.scrollIntoView({ behavior: "smooth" });
    } else {
      errorBox.classList.add("hidden");
    }
  });
</script>


<%- include('./partials/footer') %>
