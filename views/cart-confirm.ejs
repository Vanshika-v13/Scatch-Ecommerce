<%- include('./partials/header') %>

<div class="px-6 py-8 lg:px-20 font-sans relative">
  <!-- Cancel button top-right -->
  <a href="/shop" class="absolute top-6 right-6 text-red-600 underline font-medium hover:text-red-800">
    Cancel
  </a>

<div class="max-w-4xl mx-auto p-6">
  <h2 class="text-xl font-bold mb-6 text-gray-800">Confirm Your Order</h2>

  <!-- Address -->
  <div class="bg-gray-100 p-4 rounded shadow mb-6">
    <p class="mb-2"><strong>Delivery Address:</strong> <%= address.line1 %>, <%= address.city %>, <%= address.state %> - <%= address.pincode %></p>
    <p class="text-sm text-gray-600"><strong>Expected Delivery:</strong> <%= arrivalDate.toDateString() %></p>
  </div>

  <!-- Cart Items -->
  <div class="bg-white p-4 rounded shadow-sm mb-6">
    <h3 class="text-lg font-semibold mb-4">Items in Your Cart</h3>
    <ul class="divide-y">
      <% cartItems.forEach(item => { %>
        <li class="flex gap-4 py-4">
          <img src="<%= item.image %>" alt="<%= item.name %>" class="w-24 h-24 object-contain border rounded" />
          <div class="flex-1">
            <p class="font-semibold"><%= item.name %></p>
            <p class="text-sm text-gray-700">Qty: <%= item.quantity %></p>
            <% if (item.size) { %>
              <p class="text-sm text-gray-700">Size: <%= item.size %></p>
            <% } %>
            <p class="text-sm text-gray-600">Price After Discount: ₹<%= item.itemTotal.toFixed(2) %></p>
          </div>
        </li>
      <% }) %>
    </ul>
  </div>

  <!-- Total Price (Only Final Total) -->
  <div class="bg-white p-4 rounded shadow mb-6">
    <h3 class="text-lg font-semibold mb-2">Total Amount</h3>
    <p class="text-black text-xl font-bold">₹<%= finalTotal.toFixed(2) %></p>
  </div>

  <!-- Payment Method -->
  <div class="bg-white p-4 rounded shadow">
    <h3 class="text-lg font-semibold mb-4">Choose Payment Method</h3>

    <div class="space-y-3 mb-6">
      <label class="flex items-center border p-3 rounded cursor-pointer hover:bg-gray-50">
        <input type="radio" name="paymentMethod" value="COD" checked class="mr-3" id="paymentCOD">
        <span class="font-medium text-gray-800">Cash on Delivery (COD)</span>
      </label>

      <label class="flex items-center border p-3 rounded cursor-pointer hover:bg-gray-50">
        <input type="radio" name="paymentMethod" value="UPI" class="mr-3" id="paymentUPI">
        <span class="font-medium text-gray-800">UPI Payment</span>
      </label>
    </div>

    <!-- COD Form -->
    <form id="codForm" action="/place-cart-order" method="POST" class="block">
      <input type="hidden" name="addressId" value="<%= address._id %>">
      <input type="hidden" name="paymentMethod" value="COD">
      <button type="submit" class="w-full bg-yellow-500 hover:bg-yellow-600 text-white px-6 py-2 rounded font-medium">
        Place Order with COD
      </button>
    </form>

    <!-- UPI Payment Button -->
    <button id="upiPayBtn" style="display: none;" onclick="handleUPIPayment()" class="w-full bg-yellow-500 hover:bg-yellow-600 text-white px-6 py-2 rounded font-medium">
      Pay with UPI
    </button>

    <input type="hidden" id="addressId" value="<%= address._id %>">
    <input type="hidden" id="totalAmount" value="<%= finalTotal %>">
  </div>
</div>

<%- include('./partials/footer') %>
