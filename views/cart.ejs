<%- include('./partials/header') %>

<div class="bg-gray-100 min-h-screen px-4 md:px-16 py-8">

  <% if (cartIsEmpty) { %>
    <!-- Empty Cart -->
    <div class="text-center mt-24">
      <h2 class="text-2xl font-semibold text-gray-700 mb-3">
        Your cart is empty 😕
      </h2>
      <a
        href="/shop"
        class="text-blue-600 underline hover:text-blue-800"
      >
        Continue shopping
      </a>
    </div>
  <% } else { %>

    <!-- Clear Cart -->
    <div class="flex justify-end mb-4">
      <a
        href="/clearcart"
        class="bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-md text-sm"
      >
        Clear Cart
      </a>
    </div>

    <!-- Cart Items -->
    <div class="space-y-4">
      <% cartItems.forEach(item => { %>
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm hover:shadow-md transition p-4 flex flex-col md:flex-row gap-4">

          <!-- Product Image -->
          <div class="w-full md:w-32 flex justify-center items-center bg-gray-50 rounded-md p-3">
            <img
              src="<%= item.image %>"
              alt="<%= item.name %>"
              class="h-32 object-contain"
            />
          </div>

          <!-- Product Info -->
          <div class="flex-1 flex flex-col justify-between">
            <div>
              <h3 class="text-lg font-medium text-gray-800 mb-1">
                <%= item.name %>
              </h3>

              <div class="text-sm text-gray-600 space-y-1">
                <div class="flex justify-between">
                  <span>Total MRP</span>
                  <span>₹<%= item.price * item.quantity %></span>
                </div>

                <div class="flex justify-between text-green-600">
                  <span>Discount (<%= item.discount %>%)</span>
                  <span>-₹<%= item.discountAmount.toFixed(2) %></span>
                </div>
              </div>
            </div>

            <!-- Price + Quantity -->
            <div class="flex items-center justify-between mt-4">
              <div class="font-semibold text-gray-900 text-lg">
                ₹<%= item.netTotal.toFixed(2) %>
              </div>

              <div class="flex items-center border border-gray-300 rounded-md overflow-hidden">
                <button
                  class="decrease px-3 py-1 bg-gray-100 hover:bg-gray-200"
                  data-productid="<%= item._id %>"
                >−</button>

                <span class="px-4 py-1 text-sm">
                  <%= item.quantity %>
                </span>

                <button
                  class="increase px-3 py-1 bg-gray-100 hover:bg-gray-200"
                  data-productid="<%= item._id %>"
                >+</button>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Order Summary -->
    <div class="flex justify-end mt-8">
      <div class="w-full md:w-1/3 bg-white border border-gray-200 rounded-lg p-5 shadow-sm">
        <h3 class="text-lg font-semibold mb-4 text-gray-800">
          Order Summary
        </h3>

        <div class="flex justify-between text-base font-medium border-t pt-">
          <span class="pr-6 mt-2">Total Amount</span>
          <span class="mt-2">₹<%= bill.toFixed(2) %></span>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-col gap-4 mt-8 md:flex-row md:justify-between">

      <a
        href="/shop"
        class="inline-flex items-center justify-center gap-2 bg-gray-700 hover:bg-gray-800 text-white px-6 py-3 rounded-md"
      >
        Add More
        <i class="fa-solid fa-plus"></i>
      </a>

      <a
        href="/checkout"
        class="bg-yellow-500 hover:bg-amber-600 text-white px-6 py-3 rounded-md text-center font-medium"
      >
        Proceed to Buy
      </a>

    </div>

  <% } %>
</div>

<!-- Quantity Script -->
<script>
  document.querySelectorAll('.increase').forEach(btn => {
    btn.addEventListener('click', async () => {
      const productId = btn.dataset.productid;
      const res = await fetch(`/cart/increase/${productId}`, { method: "POST" });
      if (res.ok) location.reload();
    });
  });

  document.querySelectorAll('.decrease').forEach(btn => {
    btn.addEventListener('click', async () => {
      const productId = btn.dataset.productid;
      const res = await fetch(`/cart/decrease/${productId}`, { method: "POST" });
      if (res.ok) location.reload();
    });
  });
</script>

<%- include('./partials/footer') %>
