<%- include('./partials/header') %>

<div class="px-6 py-8 lg:px-20 font-sans relative">
 
  <a href="/shop" class="absolute top-6 right-6 text-red-600 underline font-medium hover:text-red-800 mb-12">
    Cancel
  </a>

  <h2 class="text-xl font-bold mb-6 mt-6">Order Summary</h2>

  <form action="/confirm-cart-order" method="POST">

  
    <label for="addressId" class="block font-medium mb-2">Select Address</label>
    <div class="flex flex-col sm:flex-row sm:items-center gap-y-2 md:gap-y-0 md:gap-x-4 mb-6">

     
      <% if (addresses.length === 0) { %>
      <div class="text-red-500 mb-2 sm:mb-0">No saved addresses found.</div>
      <% } else { %>
      <select name="addressId" required class="w-full sm:w-1/2 max-w-md px-4 py-2 border border-gray-300 rounded-lg shadow-sm mb-2 sm:mb-0
                   focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-yellow-500 transition mr-3" >
        <% addresses.forEach(address => { %>
        <option value="<%= address._id %>" <%= address._id.toString() === defaultAddressId ? "selected" : "" %>>
          <%= address.line1 %>, <%= address.city %>, <%= address.state %> - <%= address.pincode %>
          <% if (address._id.toString() === defaultAddressId) { %>(Default)<% } %>
        </option>
        <% }) %>
      </select>
      <% } %>

      <!-- Add Address Button -->
      <a href="/account/addresses/new?redirect=/checkout" class="inline-block self-start bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg text-center font-medium transition">
        + Add New Address
      </a>

    </div>

<!-- Cart Items -->
<div class="bg-white shadow rounded p-4 mb-6">
  <h3 class="text-lg font-semibold mb-4">Your Cart Items</h3>
  <div class="space-y-4">
    <% cartItems.forEach(item => { %>
    <div class="flex gap-4 border-b pb-4">
      <img src="<%= item.product.image %>" alt="Product Image" class="w-24 h-24 object-contain rounded border" />
      <div class="flex-1">
        <p class="font-semibold text-lg"><%= item.product.name %></p>
        <p class="text-sm text-gray-600">Qty: <%= item.quantity %></p>
        <p class="text-sm">Price: ₹<%= item.product.price %></p>
        <p class="text-sm text-green-700">Discount: ₹<%= item.discountAmount.toFixed(2) %></p>
        <p class="mt-1 font-semibold">Total for this item: ₹<%= item.netTotal.toFixed(2) %></p>
      </div>
    </div>
    <% }) %>
  </div>
</div>

<!-- Bill Summary -->
<div class="bg-white shadow rounded p-4 mb-6">
  <h3 class="text-lg font-semibold mb-4">Bill Summary</h3>
  <div class="space-y-2 text-gray-700">
    <div class="flex justify-between"><span>Subtotal:</span><span>₹<%= totalAmount - platformFee - shippingFee %></span></div>
    <div class="flex justify-between"><span>Platform Fee:</span><span>₹<%= platformFee %></span></div>
    <div class="flex justify-between"><span>Shipping Fee:</span><span>₹<%= shippingFee %></span></div>
    <div class="flex justify-between font-bold border-t pt-2 text-lg">
      <span>Total Payable:</span>
      <span class="text-black">₹<%= totalAmount %></span>
    </div>
  </div>
</div>

<!-- Submit Button -->
<div class="text-center">
  <button type="submit" class="bg-yellow-500 hover:bg-yellow-600 text-white px-8 py-3 rounded <%= addresses.length === 0 ? 'cursor-not-allowed opacity-60' : '' %>">
    Continue
  </button>
</div>

    

<%- include('./partials/footer') %>