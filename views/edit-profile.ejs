<%- include('./partials/header') %>

<div class="max-w-2xl mx-auto my-4 bg-white shadow-md rounded-md p-6">
  <h2 class="text-lg font-semibold mb-4">Edit Profile</h2>

  <form
    action="/account/edit"
    method="POST"
    enctype="multipart/form-data"
    class="space-y-4"
  >
    <div>
      <label class="block mb-1 font-medium">Full Name</label>
      <input
        type="text"
        name="fullname"
        value="<%= user.fullname %>"
        class="w-full px-4 py-2 border rounded"
        required
      />
    </div>

    <div>
      <label class="block mb-1 font-medium">Phone</label>
      <input
        type="text"
        name="phone"
        value="<%= user.phone %>"
        class="w-full px-4 py-2 border rounded"
      />
    </div>
    <div>
      <label class="block mb-1 font-medium">Profile Picture</label>

      <img
        src="<%= user.picture || '/images/default/avatar.jpg' %>"
        alt="Profile Avatar"
        class="h-20 w-20 mb-3 rounded-full object-cover border"
      />

      <label
        for="avatar"
        class="text-[15px] inline-block cursor-pointer bg-gray-100 px-2 py-2 rounded hover:bg-gray-200"
      >
        Choose Image
      </label>

      <input
        id="avatar"
        type="file"
        name="avatar"
        accept="image/*"
        class="hidden"
      />
    </div>

    <button
      type="submit"
      class="bg-yellow-500 text-white px-4 py-2 rounded hover:bg-yellow-600"
    >
      Save Changes
    </button>
  </form>
</div>
