<%- include('./partials/header') %>

<div
  class="max-w-xl mx-auto mt-6 sm:mt-10 bg-white p-5 sm:p-6 rounded-xl shadow"
>
  <h2 class="text-[18px] font-semibold mb-4 text-gray-700">Add New Address</h2>

  <form
    action="/account/addresses/new<%= redirectTo ? '?redirect=' + redirectTo : '' %>"
    method="POST"
    class="space-y-4"
  >
    <input type="hidden" name="redirectTo" value="<%= redirectTo %>" />

    <div>
      <label class="block text-sm font-medium text-gray-700"
        >Address Line</label
      >
      <input
        type="text"
        name="line1"
        class="w-full border px-4 py-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-400"
        required
      />
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700">City</label>
      <input
        type="text"
        name="city"
        class="w-full border px-4 py-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-400"
        required
      />
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700">State</label>
      <input
        type="text"
        name="state"
        class="w-full border px-4 py-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-400"
        required
      />
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700">Pincode</label>
      <input
        type="text"
        name="pincode"
        class="w-full border px-4 py-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-400"
        required
      />
    </div>

    <div class="flex flex-col sm:flex-row gap-3 pt-2">
      <button
        type="submit"
        class="flex-1 bg-yellow-500 text-white px-4 py-2 mr-0 md:mr-3 rounded-lg font-medium hover:bg-yellow-600 transition"
      >
        Save Address
      </button>

      <a
        href="<%= redirectTo || '/account' %>"
        class="flex-1 text-center border border-gray-300 ml-0 md:ml-3 text-gray-700 px-4 py-2 rounded-lg font-medium hover:bg-gray-100 transition"
      >
        Cancel
      </a>
    </div>
  </form>
</div>

</body>
</html>

