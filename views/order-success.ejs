<%- include('./partials/header') %>

<div class="min-h-screen bg-gray-50 px-4 py-10 font-sans">
  <div class="max-w-5xl mx-auto bg-white rounded-xl shadow-md p-6 md:p-10">

    <!-- Success Header -->
    <div class="flex items-center gap-3 mb-6">
      <div class="w-12 h-12 flex items-center justify-center rounded-full bg-green-100 text-green-600 text-2xl">
        ✔
      </div>
      <div>
        <h2 class="text-2xl font-bold text-gray-800">
          Order Confirmed!
        </h2>
        <p class="text-sm text-gray-600">
          Thank you for shopping with us. Your order has been placed successfully.
        </p>
      </div>
    </div>

    <!-- Confirmation Info -->
    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-8">
      <p class="text-sm text-gray-700">
        📧 A confirmation email with your order details will be sent shortly.
      </p>
    </div>

    <!-- Delivery Details -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      <div class="bg-gray-100 p-4 rounded-lg">
        <h3 class="font-semibold text-gray-800 mb-2">Delivery Address</h3>
        <p class="text-sm text-gray-700 leading-relaxed">
          <%= user.fullname %><br>
          <%= address.address %>, <%= address.city %><br>
          <%= address.state %> - <%= address.pincode %>
        </p>
      </div>

      <div class="bg-gray-100 p-4 rounded-lg">
        <h3 class="font-semibold text-gray-800 mb-2">Estimated Delivery</h3>
        <p class="text-sm text-gray-700">
          🚚 <%= deliveryDate.toDateString() %>
        </p>
      </div>
    </div>

    <!-- Ordered Items -->
    <h3 class="text-lg font-semibold text-gray-800 mb-4">
      Items in Your Order
    </h3>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% if (fromOrderId) { %>
        <% order.products.forEach(item => { %>
          <div class="flex gap-4 items-center bg-gray-50 border rounded-lg p-4">
            <img
              src="<%= item.product.image %>"
              class="w-24 h-24 object-contain rounded"
              alt="Product"
            />
            <div>
              <p class="font-semibold text-gray-800">
                <%= item.product.name %>
              </p>
              <p class="text-sm text-gray-600">
                Quantity: <%= item.quantity %>
              </p>
            </div>
          </div>
        <% }) %>
        <div class="col-span-full text-right text-xl font-bold text-gray-800 mt-4">
          Total Paid:
          <span class="text-green-700">₹<%= order.totalAmount %></span>
        </div>
      <% } else { %>
        <% products.forEach(item => { %>
          <div class="flex gap-4 items-center bg-gray-50 border rounded-lg p-4">
            <img
              src="<%= item.image %>"
              class="w-24 h-24 object-contain rounded"
              alt="Product"
            />
            <div>
              <p class="font-semibold text-gray-800">
                <%= item.name %>
              </p>
              <p class="text-sm text-gray-600">
                Quantity: <%= item.quantity %>
              </p>
            </div>
          </div>
        <% }) %>
        <div class="col-span-full text-right text-xl font-bold text-gray-800 mt-4">
          Total Paid:
          <span class="text-green-700">₹<%= totalAmount %></span>
        </div>
      <% } %>
    </div>

    <!-- CTA -->
    <div class="mt-10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <a
        href="/shop"
        class="inline-block bg-yellow-500 hover:bg-yellow-600 text-white font-medium px-8 py-3 rounded-lg transition"
      >
        Continue Shopping
      </a>

      <p class="text-sm text-gray-500">
        Need help? Visit your account or contact support.
      </p>
    </div>

  </div>
</div>

<%- include('./partials/footer') %>
