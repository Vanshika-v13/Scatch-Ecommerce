<%- include('./partials/header') %>

<% if (success.length > 0) { %>
<div id="flash-msg" 
     class="
     relative flex sm:inline-flex justify-center sm:justify-between
     mx-auto sm:fixed sm:top-4 sm:left-1/2 sm:transform sm:-translate-x-1/2
     z-50
     bg-yellow-400 text-black px-4 py-2 rounded-lg shadow-lg text-center
     gap-4
     transition-all duration-300 opacity-100 translate-y-0">

  <span class="flex-1 text-sm sm:text-base whitespace-nowrap text-center"><%= success %></span>

  <button id="flash-close" class="text-gray-700 hover:text-gray-900 font-bold ml-2">
    ×
  </button>
</div>
<% } %>


<div class="w-full min-h-screen flex flex-col lg:flex-row px-4 sm:px-6 lg:px-20 py-6 lg:py-12 bg-[#f4f4f4] font-sans">

  
  <aside class="w-full lg:w-1/5 xl:w-1/6 pr-0 lg:pr-4 mb-8 lg:mb-0 border-b lg:border-b-0 lg:border-r border-gray-300">

    
    <div class="mb-10">
      <h3 class="text-[18px] md:text-xl font-semibold text-gray-800 mb-3">Sort By</h3>
      <form method="GET" action="/shop">
        <% if (typeof filter !== 'undefined' && filter) { %>
        <input type="hidden" name="filter" value="<%= filter %>">
        <% } %>
        <select name="sort" onchange="this.form.submit()" class="w-full border-gray-300 rounded px-3 py-2 shadow-sm text-gray-700 focus:ring-rose-400">
          <option value="popular" <%= sort === 'popular' ? 'selected' : '' %>>Popular</option>
          <option value="new" <%= sort === 'new' ? 'selected' : '' %>>Newest</option>
          <option value="priceLowHigh" <%= sort === 'priceLowHigh' ? 'selected' : '' %>>Price: Low to High</option>
          <option value="priceHighLow" <%= sort === 'priceHighLow' ? 'selected' : '' %>>Price: High to Low</option>
        </select>
      </form>
    </div>

   
    <div class="flex flex-col items-start mb-3">
      
      <h3 class="text-[18px] md:text-xl font-semibold text-gray-800 mb-2">
        Filters
      </h3>

   
      <div class="flex items-center space-x-6 lg:flex-col lg:flex-wrap lg:items-start">
        
        <a href="/shop" class="my-1 text-gray-600 hover:text-yellow-600 transition <%= !filter ? 'text-yellow-600 font-semibold' : '' %>">
          All Watches
        </a>

       
        <a href="/shop?filter=discounted" class="my-1 text-gray-600 hover:text-yellow-600 transition <%= filter === 'discounted' ? 'text-yellow-600 font-semibold' : '' %>">
          Discounted
        </a>
      </div>
    </div>

  </aside>

  <!-- Products Grid -->
  <main class="w-full mx-auto lg:w-3/4 pl-0 lg:pl-6">

    <% if (filter === 'discounted') { %>
    <div class="text-gray-600 font-medium mb-4">Showing Discounted Watches</div>
    <% } else { %>
    <div class="text-gray-700 font-medium mb-4">Showing All Watches</div>
    <% } %>

    <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-10">
      <% products.forEach(function(product) { %>
      <div class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-lg transition duration-300 border border-gray-200 group">

        
        <div class="w-full h-56 bg-[<%= product.bgcolor %>] flex items-center justify-center">
          <% if (product.image) { %>
          <img class="h-44 object-contain transition duration-200 group-hover:scale-105" src="<%= product.image %>" alt="<%= product.name %>">
          <% } else { %>
          <div class="text-center text-sm text-gray-400">No image</div>
          <% } %>
        </div>

       
        <div class="bg-[<%= product.panelcolor %>] text-[<%= product.textcolor %>] px-5 py-4 space-y-2">
          <h3 class="text-md font-semibold tracking-wide"><%= product.name %></h3>
          <div class="text-sm flex items-center gap-2">
            <span>₹ <%= product.price %></span>
            <% if (product.discount > 0) { %>
            <span class="line-through text-gray-400">₹ <%= Math.floor(product.price / (1 - product.discount / 100)) %></span>
            <span class="text-green-600 font-medium">-<%= product.discount %>%</span>
            <% } %>
          </div>

          
          <div class="pt-3 flex gap-3">
            <a href="/addtocart/<%= product._id %>" class="bg-gray-900 text-white text-xs sm:text-sm px-4 py-2 rounded-md hover:bg-gray-700 transition">
              Add to Cart
            </a>
            <a href="/buynow/<%= product._id %>" class="bg-yellow-500 text-white text-xs sm:text-sm px-4 py-2 rounded-md hover:bg-yellow-600 transition">
              Buy Now
            </a>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </main>
</div>

<script>
  setTimeout(() => {
    const msg = document.getElementById("flash-msg");
    if (msg) msg.remove();
  }, 500);
</script>

<%- include('./partials/footer') %>
